### ----------------------------------------------------------------------------
### List books - all accessible books
### ----------------------------------------------------------------------------

GET {{host}}/books
Authorization: Bearer {{jwt}}

> {%
  client.test("List books returns 200", function () {
    client.assert(response.status === 200, "Expected status 200");
  });
  client.test("List books returns array", function () {
    client.assert(Array.isArray(response.body), "Expected array");
  });
%}

<> 2026-04-02T171347-1.200.json

### ----------------------------------------------------------------------------
### List books - by specific accessible library
### ----------------------------------------------------------------------------

GET {{host}}/books?library=65f100000000000000000001
Authorization: Bearer {{jwt}}

> {%
  client.test("Filtered books returns 200", function () {
    client.assert(response.status === 200, "Expected status 200");
  });
  client.test("Filtered books returns array", function () {
    client.assert(Array.isArray(response.body), "Expected array");
  });
%}

<> 2026-04-02T171347-2.200.json

### ----------------------------------------------------------------------------
### Get book by id - success
### ----------------------------------------------------------------------------

GET {{host}}/books/{{createdBookId}}
Authorization: Bearer {{jwt}}

> {%
  client.test("Get book by id returns 200", function () {
    client.assert(response.status === 200, "Expected status 200");
  });
  client.test("Fetched book id matches created id", function () {
    client.assert(response.body._id === client.global.get("createdBookId"), "Expected matching id");
  });
%}

<> 2026-04-02T171348.200.json

### ----------------------------------------------------------------------------
### Get book by id - unauthorized
### ----------------------------------------------------------------------------

GET {{host}}/books/{{createdBookId}}

> {%
  client.test("Missing token returns 401", function () {
    client.assert(response.status === 401, "Expected status 401");
  });
%}

<> 2026-04-02T171348.401.json

### ----------------------------------------------------------------------------
### Update book - success
### ----------------------------------------------------------------------------

PUT {{host}}/books/{{createdBookId}}
Authorization: Bearer {{jwt}}
Content-Type: {{contentType}}

{
  "title": "Node.js Patterns - Updated",
  "pages": 640
}

> {%
  client.test("Update book returns 200", function () {
    client.assert(response.status === 200, "Expected status 200");
  });
  client.test("Updated title is returned", function () {
    client.assert(response.body.title === "Node.js Patterns - Updated", "Expected updated title");
  });
  client.test("Updated pages are returned", function () {
    client.assert(response.body.pages === 640, "Expected updated pages");
  });
%}

<> 2026-04-02T171348-1.200.json

