### ============================================================================
### Book Management API - IntelliJ HTTP Client file
### Save as: requests.http
### ============================================================================
### Notes:
### 1. Start the app first
### 2. This file logs in, stores the JWT, and reuses it automatically
### 3. Run requests one by one from top to bottom
### ============================================================================

@host = http://localhost:3000
@contentType = application/json

### ----------------------------------------------------------------------------
### Health check
### ----------------------------------------------------------------------------

GET {{host}}/health

> {%
  client.test("Health returns 200", function () {
    client.assert(response.status === 200, "Expected status 200");
  });
  client.test("Health response contains ok status", function () {
    client.assert(response.body.status === "ok", "Expected status to be ok");
  });
%}

<> 2026-04-02T171346.200.json
<> 2026-04-02T171309.200.json

### ----------------------------------------------------------------------------
### Login - admin
### ----------------------------------------------------------------------------

POST {{host}}/login
Content-Type: {{contentType}}

{
  "username": "admin",
  "password": "password123"
}

> {%
  client.test("Login returns 200", function () {
    client.assert(response.status === 200, "Expected status 200");
  });
  client.test("Login returns token", function () {
    client.assert(!!response.body.token, "Expected JWT token");
  });
  client.global.set("jwt", response.body.token);
%}

<> 2026-04-02T171346-1.200.json
<> 2026-04-02T171318.200.json

### ----------------------------------------------------------------------------
### Login - invalid credentials
### ----------------------------------------------------------------------------

POST {{host}}/login
Content-Type: {{contentType}}

{
  "username": "admin",
  "password": "wrong-password"
}

> {%
  client.test("Invalid login returns 401", function () {
    client.assert(response.status === 401, "Expected status 401");
  });
%}

<> 2026-04-02T171346.401.json

### ----------------------------------------------------------------------------
### Create book - success
### ----------------------------------------------------------------------------

POST {{host}}/books
Authorization: Bearer {{jwt}}
Content-Type: {{contentType}}

{
  "title": "Node.js Patterns",
  "author": "Mario Casciaro",
  "authorCountry": "IT",
  "publishedDate": "2020-01-01",
  "pages": 526,
  "library": "65f100000000000000000001"
}

> {%
  client.test("Create book returns 201", function () {
    client.assert(response.status === 201, "Expected status 201");
  });
  client.test("Created book has title", function () {
    client.assert(response.body.title === "Node.js Patterns", "Expected created title");
  });
  client.test("Created book has id", function () {
    client.assert(!!response.body._id, "Expected book id");
  });
  client.global.set("createdBookId", response.body._id);
%}

<> 2026-04-02T171347.201.json

### ----------------------------------------------------------------------------
### Create book - validation error
### ----------------------------------------------------------------------------

POST {{host}}/books
Authorization: Bearer {{jwt}}
Content-Type: {{contentType}}

{
  "title": "",
  "author": "Unknown",
  "authorCountry": "US",
  "publishedDate": "2020-01-01",
  "pages": 0,
  "library": "65f100000000000000000001"
}

> {%
  client.test("Invalid create book returns 400", function () {
    client.assert(response.status === 400, "Expected status 400");
  });
  client.test("Validation error message exists", function () {
    client.assert(response.body.message === "Validation failed", "Expected validation failed");
  });
%}

<> 2026-04-02T171347.400.json

### ----------------------------------------------------------------------------
### Create book - forbidden library
### ----------------------------------------------------------------------------

POST {{host}}/login
Content-Type: {{contentType}}

{
  "username": "reader_uk",
  "password": "password123"
}

> {%
  client.test("reader_uk login returns 200", function () {
    client.assert(response.status === 200, "Expected status 200");
  });
  client.global.set("readerJwt", response.body.token);
%}

<> 2026-04-02T171347.200.json

###

POST {{host}}/books
Authorization: Bearer {{readerJwt}}
Content-Type: {{contentType}}

{
  "title": "Forbidden Book",
  "author": "Unknown",
  "authorCountry": "US",
  "publishedDate": "2020-01-01",
  "pages": 100,
  "library": "65f100000000000000000001"
}

> {%
  client.test("Forbidden create book returns 403", function () {
    client.assert(response.status === 403, "Expected status 403");
  });
%}

